{
    "name": "@orians/core",
    "version": "1.0.0",
    "homepage": "https://github.com/ComusBala96/core.git",
    "description": "A npm package of core for orians.",
    "type": "module",
    "main": "build/cjs/index.js",
    "module": "build/esm/index.js",
    "types": "build/esm/index.d.ts",
    "exports": {
        ".": {
            "require": "./build/cjs/index.js",
            "import": "./build/esm/index.js"
        },
        "./node": {
            "require": "./build/cjs/node/index.js",
            "import": "./build/esm/node/index.js"
        },
        "./plugins": {
            "require": "./build/cjs/css/plugins.css",
            "import": "./build/esm/css/plugins.css"
        },
        "./select2.min.css": {
            "require": "./build/cjs/css/select2.min.css",
            "import": "./build/esm/css/select2.min.css"
        },
        "./tailwind": {
            "require": "./build/cjs/tailwind/index.js",
            "import": "./build/esm/tailwind/index.js"
        },
        "./tailwind/base": {
            "require": "./build/cjs/tailwind/base.css",
            "import": "./build/esm/tailwind/base.css"
        }
    },
    "license": "MIT",
    "keywords": [
        "orians",
        "npm",
        "@orians",
        "@orians/core",
        "core"
    ],
    "author": {
        "name": "OrianSoft",
        "email": "info@oriansoft.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ComusBala96/core.git"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "scripts": {
        "clean": "rm -rf build",
        "build:esm": "tsc -p tsconfig.esm.json",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:esm:watch": "tsc -p tsconfig.esm.json --watch",
        "build:cjs:watch": "tsc -p tsconfig.cjs.json --watch",
        "build:css": "cpy \"src/**/*.css\" build/esm --parents && cpy \"src/**/*.css\" build/cjs --parents",
        "build:extraTypes": "cpy \"src/**/*.d.ts\" build/esm --parents && cpy \"src/**/*.d.ts\" build/cjs --parents",
        "watch:assets": "chokidar \"src/**/*.{css,d.ts}\" -c \"npm run build:css && npm run build:extraTypes\"",
        "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:extraTypes && npm run build:css",
        "dev": "npm run clean && concurrently -k -n ESM,CJS,ASSETS \"npm:build:esm:watch\" \"npm:build:cjs:watch\" \"npm:watch:assets\""
    },
    "dependencies": {
        "datatables.net-buttons-dt": "^3.2.4",
        "datatables.net-dt": "^2.3.2",
        "datatables.net-responsive-dt": "^3.0.5",
        "datatables.net-searchbuilder-dt": "^1.8.3",
        "datatables.net-searchpanes-dt": "^2.3.4",
        "datatables.net-select-dt": "^3.0.1",
        "highcharts": "^12.2.0",
        "jodit": "^4.6.2",
        "moment": "^2.30.1",
        "pdfmake": "^0.3.7",
        "summernote": "^0.9.1",
        "sweetalert2": "^11.15.3",
        "swiper": "^11.2.6",
        "select2": "^4.1.0-rc.0",
        "jquery-datetimepicker": "^2.5.21",
        "xlsx": "^0.18.5",
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.4.47",
        "tailwindcss": "^3.4.13"
    },
    "devDependencies": {
        "jquery": "^4.0.0",
        "jquery-confirm": "^3.3.4",
        "jquery-datetimepicker": "^2.5.21",
        "jquery-validation": "^1.21.0",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@types/node": "^25.5.0",
        "chokidar-cli": "^3.0.0",
        "concurrently": "^9.2.1",
        "cpy-cli": "^7.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-react": "^7.34.3",
        "eslint-plugin-react-hooks": "^5.1.0",
        "prettier": "^3.3.2",
        "typescript": "^5.9.3"
    }
}